{
  "name": "@diskette/dialtone",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diskettejs/dialtone.git"
  },
  "files": [
    "binding.d.ts",
    "binding.js",
    "index.d.ts",
    "index.js"
  ],
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --esm --platform --release --js binding.js --dts binding.d.ts",
    "build:debug": "napi build --esm --platform --js binding.js --dts binding.d.ts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@napi-rs/cli": "^3.7.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "napi": {
    "binaryName": "dialtone",
    "constEnum": false,
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  }
}
